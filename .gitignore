# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example          # Always commit the example template

# ── Database / storage ─────────────────────────────────────────────────────────
chroma_store/
uploads/
*.sqlite3
*.db

# ── Alembic generated ──────────────────────────────────────────────────────────
