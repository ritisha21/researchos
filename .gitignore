alembic/versions/__pycache__/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
build/
frontend/.env.local

# ── Docker ────────────────────────────────────────────────────────────────────
