# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME="ResearchOS"
APP_ENV="development"           # development | staging | production
DEBUG=true
LOG_LEVEL="INFO"

# ─── Server ───────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://researchos:researchos@localhost:5432/researchos_db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR="./chroma_store"
CHROMA_COLLECTION_NAME="research_papers"

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-1.5-flash"          # Flash = faster + cheaper for MVP
GEMINI_EMBEDDING_MODEL="models/text-embedding-004"

# ─── Semantic Scholar ─────────────────────────────────────────────────────────
# Free tier: 100 req/5min unauthenticated | Apply at semanticscholar.org for a key
SEMANTIC_SCHOLAR_API_KEY=""             # Optional but recommended
SEMANTIC_SCHOLAR_BASE_URL="https://api.semanticscholar.org/graph/v1"

# ─── arXiv ────────────────────────────────────────────────────────────────────
# No API key needed — arXiv is open
ARXIV_MAX_RESULTS=10

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=50
